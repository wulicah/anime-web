{
  "name": "fanlu",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "番录 FanLu - 个人向动漫追踪与资讯站",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,css,md}\""
  },
  "dependencies": {
    "@vueuse/core": "^11.1.0",
    "dayjs": "^1.11.13",
    "dexie": "^4.0.8",
    "pinia": "^2.2.4",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.5.4",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5",
    "vue-tsc": "^2.1.6"
  }
}
